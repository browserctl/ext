{
  "manifest_version": 3,
  "key": "",
  "name": "Chrome Use",
  "version": "0.2.1",
  "description": "Browser automation for OpenClaw Skill",
  "permissions": [
    "tabs",
    "debugger",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Chrome Use",
    "default_popup": "popup.html"
  }
}
